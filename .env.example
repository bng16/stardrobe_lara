APP_NAME="Creator Marketplace"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Database Configuration
# For production, use MySQL 8.0+
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=creator_marketplace
DB_USERNAME=root
DB_PASSWORD=

# Session Configuration
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# Broadcasting & Cache
BROADCAST_CONNECTION=log
CACHE_STORE=redis
# CACHE_PREFIX=

# Queue Configuration
# Use Redis for production queue processing
QUEUE_CONNECTION=redis

# Redis Configuration
# Required for queue processing and caching
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Mail Configuration
# Development: Use 'log' or Mailtrap
# Production: Use Resend, Mailgun, or SES
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Mailtrap (Development Only)
# MAIL_MAILER=smtp
# MAIL_HOST=sandbox.smtp.mailtrap.io
# MAIL_PORT=2525
# MAIL_USERNAME=your_mailtrap_username
# MAIL_PASSWORD=your_mailtrap_password

# Resend (Production)
# MAIL_MAILER=resend
# RESEND_API_KEY=your_resend_api_key

# Mailgun (Production Alternative)
# MAIL_MAILER=mailgun
# MAILGUN_DOMAIN=your_domain.com
# MAILGUN_SECRET=your_mailgun_secret
# MAILGUN_ENDPOINT=api.mailgun.net

# File Storage Configuration
# Use 's3' for AWS S3 or 'r2' for Cloudflare R2
FILESYSTEM_DISK=local

# AWS S3 Configuration
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false
# AWS_URL=https://your-bucket.s3.amazonaws.com

# Cloudflare R2 Configuration (Alternative to S3)
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=
# R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
# R2_PUBLIC_URL=https://your-public-domain.com

# Stripe Payment Configuration
# Get keys from https://dashboard.stripe.com/apikeys
STRIPE_KEY=pk_test_your_publishable_key
STRIPE_SECRET=sk_test_your_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Stripe Connect Configuration (for creator payouts)
# STRIPE_CONNECT_CLIENT_ID=ca_your_connect_client_id

# Admin Alert Email
# Email address to receive critical job failure alerts
ADMIN_ALERT_EMAIL=admin@example.com

# Queue Worker Configuration
QUEUE_RETRY_AFTER=90
QUEUE_MAX_ATTEMPTS=3

# Rate Limiting
RATE_LIMIT_BID_SUBMISSION=10
RATE_LIMIT_API=60

# File Upload Limits (in KB)
MAX_PRODUCT_IMAGE_SIZE=5120
MAX_PROFILE_IMAGE_SIZE=2048

# Auction Configuration
AUCTION_PAYMENT_WINDOW_HOURS=48

# CDN Configuration (Optional)
# Set ASSET_URL to your CDN domain to serve static assets from CDN
# Leave empty to serve assets from your application server
# Examples:
#   CloudFlare: https://cdn.example.com
#   AWS CloudFront: https://d111111abcdef8.cloudfront.net
#   Custom CDN: https://assets.example.com
ASSET_URL=

# Memcached (Optional)
MEMCACHED_HOST=127.0.0.1

VITE_APP_NAME="${APP_NAME}"
