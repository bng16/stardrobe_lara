# Production Environment Configuration
APP_ENV=production
APP_DEBUG=false

# Asset Optimization
VITE_MINIFY=true
VITE_SOURCEMAP=false

# CDN Configuration
# Set to your CDN URL for production asset delivery
# Example: https://cdn.example.com or https://d111111abcdef8.cloudfront.net
ASSET_URL=

# Cache Configuration
CACHE_DRIVER=redis
SESSION_DRIVER=redis
QUEUE_CONNECTION=redis

# View Caching (Enable in production)
VIEW_CACHE_PATH=/path/to/storage/framework/views
